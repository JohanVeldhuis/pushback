<Window xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Pushback"
        Width="760" Height="640"
        MinWidth="600" MinHeight="500"
        WindowStartupLocation="CenterScreen">
    <Window.Resources>
        <!-- Accent style for the safe dry-run button so users learn to reach for it first. -->
        <Style x:Key="PreviewButton" TargetType="Button">
            <Setter Property="Background" Value="#0E639C"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Padding" Value="14,6"/>
            <Setter Property="BorderBrush" Value="#0A4B7A"/>
            <Setter Property="BorderThickness" Value="1"/>
        </Style>
    </Window.Resources>

    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/> <!-- detection panel -->
            <RowDefinition Height="Auto"/> <!-- package filter -->
            <RowDefinition Height="Auto"/> <!-- action buttons -->
            <RowDefinition Height="Auto"/> <!-- progress + cancel -->
            <RowDefinition Height="*"/>    <!-- results -->
            <RowDefinition Height="Auto"/> <!-- advanced + log + status bar -->
        </Grid.RowDefinitions>

        <!-- Row 0: Detection panel ============================================ -->
        <GroupBox Header="Simulator" Grid.Row="0" Padding="8" Margin="0,0,0,8">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <TextBlock x:Name="bannerNoSim"
                           Grid.Row="0" Grid.ColumnSpan="3"
                           Text="No MSFS installation detected. Click Browse… to select your Community folder manually."
                           Foreground="DarkRed" Margin="0,0,0,6"
                           Visibility="Collapsed" TextWrapping="Wrap"/>

                <TextBlock Grid.Row="1" Grid.Column="0" Text="Sim:" VerticalAlignment="Center" Margin="0,0,8,0"/>
                <ComboBox  x:Name="cmbSim" Grid.Row="1" Grid.Column="1"/>
                <Button    x:Name="btnBrowse" Grid.Row="1" Grid.Column="2"
                           Content="Browse…" Margin="8,0,0,0" Padding="10,4"/>

                <TextBlock Grid.Row="2" Grid.Column="0" Text="Folder:" VerticalAlignment="Center" Margin="0,8,8,0"/>
                <TextBox   x:Name="txtCommunityFolder" Grid.Row="2" Grid.Column="1" Grid.ColumnSpan="2"
                           IsReadOnly="True" Margin="0,8,0,0"/>
            </Grid>
        </GroupBox>

        <!-- Row 1: Package filter ============================================ -->
        <GroupBox Header="Packages" Grid.Row="1" Padding="8" Margin="0,0,0,8">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Row="0" Grid.Column="0"
                           Text="Tick packages to scope the run. Leave all unticked to scan the entire Community folder."
                           Foreground="Gray" Margin="0,0,0,6" TextWrapping="Wrap"/>
                <TextBlock x:Name="txtPkgCount" Grid.Row="0" Grid.Column="1"
                           Text="0 selected of 0 packages"
                           Foreground="Gray" Margin="8,0,0,6" VerticalAlignment="Center"/>

                <Grid Grid.Row="1" Grid.ColumnSpan="2" Margin="0,0,0,6">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="220"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <Grid Grid.Column="0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBox x:Name="txtPkgSearch" Grid.Column="0" Padding="6,2"
                                 ToolTip="Type to filter package names"
                                 VerticalAlignment="Center"/>
                        <Button x:Name="btnPkgSearchClear" Grid.Column="1" Content="x"
                                Padding="6,2" Margin="4,0,0,0"
                                ToolTip="Clear package search"/>
                    </Grid>
                    <StackPanel Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Right" Margin="8,0,0,0">
                        <Button x:Name="btnPkgPresetFSLTL" Content="FSLTL" Padding="8,2" Margin="0,0,4,0"
                                ToolTip="Select only fsltl-traffic-base"/>
                        <Button x:Name="btnPkgPresetAIG"   Content="AIG*"  Padding="8,2" Margin="0,0,4,0"
                                ToolTip="Select only packages whose name starts with AIG"/>
                        <Button x:Name="btnPkgSelectAll"   Content="All"   Padding="8,2" Margin="0,0,4,0"/>
                        <Button x:Name="btnPkgClear"       Content="None"  Padding="8,2" Margin="0,0,4,0"/>
                        <Button x:Name="btnPkgRefresh"     Content="Refresh" Padding="8,2"/>
                    </StackPanel>
                </Grid>

                <Border Grid.Row="2" Grid.ColumnSpan="2"
                        BorderBrush="#CCCCCC" BorderThickness="1" Height="170">
                    <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                        <ItemsControl x:Name="lstPackages" Margin="4">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <StackPanel Orientation="Vertical"/>
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                        </ItemsControl>
                    </ScrollViewer>
                </Border>
            </Grid>
        </GroupBox>

        <!-- Row 2: Action buttons ============================================= -->
        <Grid Grid.Row="2" Margin="0,0,0,8">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <StackPanel Grid.Row="0" Orientation="Horizontal">
                <Button x:Name="btnDryRun" Content="Dry-run preview"
                        Style="{StaticResource PreviewButton}" Margin="0,0,12,0"/>
                <Button x:Name="btnDisable" Content="Disable pushback" Padding="14,6" Margin="0,0,8,0"/>
                <Button x:Name="btnEnable"  Content="Enable pushback"  Padding="14,6" Margin="0,0,16,0"/>
                <Button x:Name="btnRestore" Content="Restore backups"  Padding="14,6" Margin="0,0,8,0"/>
            </StackPanel>

            <Grid Grid.Row="1" Margin="0,6,0,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <TextBlock x:Name="txtScopeSummary" Grid.Column="0"
                           Text="Scope: All packages"
                           Foreground="#8A5A00" FontWeight="SemiBold"/>
                <TextBlock x:Name="txtScopeDetails" Grid.Column="1"
                           Text="" Margin="12,0,0,0" Foreground="Gray" VerticalAlignment="Center"/>
                <Button x:Name="btnScopeAcknowledge" Grid.Column="2"
                        Content="Acknowledge all-scope risk"
                        Margin="12,0,0,0" Padding="8,2"
                        Visibility="Collapsed"
                        ToolTip="Required once per app session before using Disable/Enable with all packages selected"/>
            </Grid>
        </Grid>

        <!-- Row 3: Progress + cancel ========================================== -->
        <Grid Grid.Row="3" Margin="0,0,0,8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <ProgressBar x:Name="prgProgress" Grid.Column="0" Height="18" Minimum="0" Maximum="1" Value="0"/>
            <Button      x:Name="btnCancel" Grid.Column="1" Content="Cancel"
                         Margin="8,0,0,0" Padding="10,2" Visibility="Collapsed"/>
        </Grid>

        <!-- Row 4: Results pane =============================================== -->
        <GroupBox Header="Results" Grid.Row="4" Padding="4">
            <TabControl x:Name="lstResults">
                <TabItem Header="Changed (0)" x:Name="tabChanged">
                    <ListBox x:Name="lstChanged"/>
                </TabItem>
                <TabItem Header="Would change (0)" x:Name="tabWouldChange">
                    <ListBox x:Name="lstWouldChange"/>
                </TabItem>
                <TabItem Header="Unchanged (0)" x:Name="tabUnchanged">
                    <ListBox x:Name="lstUnchanged"/>
                </TabItem>
                <TabItem Header="Errors (0)" x:Name="tabErrors">
                    <ListBox x:Name="lstErrors"/>
                </TabItem>
            </TabControl>
        </GroupBox>

        <!-- Row 5: Advanced + log + status =================================== -->
        <Grid Grid.Row="5" Margin="0,8,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <Expander Grid.Row="0" Grid.Column="0" Grid.ColumnSpan="2" Header="Advanced" Margin="0,0,0,4">
                <StackPanel>
                    <CheckBox x:Name="chkOverwriteBak"
                              Content="Overwrite existing .bak files (use only if you know what you're doing)"
                              Margin="0,4,0,0"/>
                </StackPanel>
            </Expander>

            <TextBlock x:Name="txtStatus" Grid.Row="1" Grid.Column="0"
                       Text="Ready." VerticalAlignment="Center" Foreground="Gray"/>
            <Button    x:Name="btnOpenLog" Grid.Row="1" Grid.Column="1"
                       Content="Open log" Padding="10,2"/>
        </Grid>
    </Grid>
</Window>
